<section id="about">
  <div class="about-inner">
    <h2 class="about-title" id="aboutTitle">
      Aprende, conecta y <span class="blue-gradient">construye con IA</span>
    </h2>

    <p class="about-desc" id="aboutDesc">
      <span class="bolder">AI Developer Day: Build with AI 2026</span> es el espacio
      donde la inteligencia artificial deja de ser tendencia y se convierte en producto.
      Reunimos a developers, diseñadores, estudiantes y profesionales tech que están
      construyendo soluciones reales con IA.
    </p>
    <p class="about-desc" id="aboutDesc">
      Si estás experimentando, desarrollando o liderando proyectos con IA, este es
      tu lugar para aprender, compartir y conectar con la comunidad que está redefiniendo
      el desarrollo con inteligencia artificial.
    </p>

    <p class="about-desc" id="aboutDesc">
      Un evento pensado para inspirarte, darte herramientas prácticas y conectarte con la comunidad que está construyendo el presente y el futuro con IA.
Organizado por Google Developer Group Callao.</p>

    <a href="#register" class="about-cta" id="aboutCta">
      <span>Reserva tu lugar</span>
    </a>
  </div>
</section>

<style lang="scss">
  #about {
    background: var(--blue-ultra);
    padding: 120px 80px;
    position: relative;
    overflow: hidden;

    &::before {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      border: 2px solid rgba(56, 113, 205, 0.1);
      border-radius: 4px;
      top: -50px;
      right: -50px;
      transform: rotate(20deg);
    }

    &::after {
      content: "";
      position: absolute;
      width: 100px;
      height: 100px;
      border: 2px solid rgba(66, 133, 244, 0.08);
      border-radius: 4px;
      bottom: -30px;
      left: -20px;
      transform: rotate(15deg);
    }

    @media (max-width: 900px) {
      padding: 80px 28px;
    }
  }

  .about-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .about-title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #0d1117;
    margin-bottom: 28px;
    opacity: 0;
  }

  .about-desc {
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.8;
    color: rgba(13, 17, 23, 0.6);
    padding: 0 0 20px;
    opacity: 0;
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 14px;
    padding: 14px 36px;
    background: var(--blue-mid);
    color: var(--white);
    border-radius: 40px;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transition:
      transform 0.2s,
      box-shadow 0.3s;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 40px;
      background: var(--blue-deep);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    span {
      position: relative;
      z-index: 1;
    }

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(66, 133, 244, 0.3);

      &::after {
        opacity: 1;
      }
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "#about",
      start: "top 75%",
    },
  });

  tl.to("#aboutEyebrow", {
    opacity: 1,
    y: 0,
    duration: 0.5,
    ease: "power2.out",
  })
    .to(
      "#aboutTitle",
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: "power3.out",
      },
      "-=0.2",
    )
    .to(
      "#aboutDesc",
      {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
      },
      "-=0.3",
    )
    .to(
      "#aboutCta",
      {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
      },
      "-=0.2",
    );
</script>
