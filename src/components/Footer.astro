---

<footer class="footer" id="footer">
  <div class="footer-inner">
    <div class="logo">
      <img src="/images/gdg-logo-black.png" alt="logo GDG Callao" />
    </div>

    <div class="footer-social">
      Síguenos:
      <a
        href="https://www.linkedin.com/company/google-developer-groups-callao/"
        target="_blank"
        rel="noopener"
        aria-label="LinkedIn"
      >
        <img src="/images/ico-linkedin.png" alt="LinkedIn" />
      </a>
      <a
        href="https://www.instagram.com/gdg_callao/"
        target="_blank"
        rel="noopener"
        aria-label="Instagram"
      >
        <img src="/images/ico-instagram.png" alt="Instagram" />
      </a>
      <a
        href="https://x.com/gdg_callao"
        target="_blank"
        rel="noopener"
        aria-label="X"
      >
        <img src="/images/ico-x.png" alt="X / Twitter" />
      </a>
      <a
        href="https://www.youtube.com/@GDG_Callao"
        target="_blank"
        rel="noopener"
        aria-label="YouTube"
      >
        <img class="yt-icon" src="/images/ico-youtube.png" alt="YouTube" />
      </a>
      <a
        href="https://www.tiktok.com/@gdg.callao"
        target="_blank"
        rel="noopener"
        aria-label="Tiktok"
      >
        <img src="/images/ico-tiktok.png" alt="Tik Tok" />
      </a>
    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    background-color: var(--blue-pale);
    color: var(--dark);
    font-weight: 500;
    padding: 2rem 3rem;

    .footer-inner {
      display: flex;
      justify-content: space-between;

      @media (max-width: 765px) {
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }
    }

    .footer-social {
      display: flex;
      align-items: center;
      gap: 0.7rem;

      a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition:
          transform 0.2s,
          opacity 0.2s;

        &:hover {
          transform: translateY(-2px);
          opacity: 0.7;
        }
      }
      img {
        width: 25px;
        height: auto;
        object-fit: contain;
        display: block;
      }

      .yt-icon {
        width: 28px;
        height: 30px;
      }
    }
    .logo {
      img {
        width: 275px;
        height: auto;

        @media (max-width: 765px) {
          border-bottom: 1px solid;
          padding: 0 0 1rem;
        }
      }
    }
  }
</style>
