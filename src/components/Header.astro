---

---

<header id="mainHeader">
  <a href="#" class="header-logo">
    <img class="logo" src="/images/logo-bwa-aidevday.png" alt="" />
  </a>
  <div class="content">
    <nav>
    <a href="#join">Participa</a>
    <a href="#sponsors">Sponsors</a>
    <a href="#agenda">Agenda</a>
  </nav>
  <a
      href="https://gdg.community.dev/e/m9699h/"
      target="_blank"
      class="btn-primary"
    >
      <span>Regístrate</span></a
    >
  </div>
</header>

<style lang="scss">
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 52px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition:
      background 0.4s ease,
      box-shadow 0.4s ease,
      border-bottom 0.4s ease;
    &.scrolled {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(66, 133, 244, 0.1);
      box-shadow: 0 2px 24px rgba(66, 133, 244, 0.07);
    }

    .content {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
    }
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 10px;

    .logo {
      width: 200px;
      height: auto;

      @media (max-width: 765px) {
        width: 160px;
      }
    }
  }

  .logo-squares {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5px;
    width: 22px;
    height: 22px;
  }

  .logo-text {
    font-family: var(--sans);
    font-weight: 400;
    font-size: 15px;
    color: #0d1117;
  }

  nav {
    display: flex;
    gap: 32px;
    align-items: center;
    font-family: var(--secondary);

    a {
      font-size: 1rem;
      letter-spacing: 0.1em;
      color: rgba(13, 17, 23, 0.45);
      transition: color 0.25s;

      &:hover {
        color: var(--blue-mid);
      }
    }
  }

  @media (max-width: 860px) {
    header {
      padding: 0 24px;
    }
    nav {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const header = document.getElementById("mainHeader");

  ScrollTrigger.create({
    trigger: "body",
    start: "top+=80 top",
    onEnter: () => header?.classList.add("scrolled"),
    onLeaveBack: () => header?.classList.remove("scrolled"),
  });
</script>
