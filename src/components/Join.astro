<section id="join">
  <div class="join-half speaker">
    <div class="join-content">
      <div class="join-icon">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"
          ></path>
        </svg>
      </div>

      <span class="join-eyebrow">Call for speakers</span>

      <h2 class="join-title">
        ¿Tienes algo<br />
        que <em>enseñar?</em>
      </h2>

      <p class="join-desc">
        Sé parte de los speakers que nos acompañarán en el AI Developer Day y
        comparte tus conocimientos con nuestra comunidad. Si tienes una charla,
        taller o demo que te gustaría compartir, no dudes en postularte.
        ¡Estamos ansiosos por escucharte!
      </p>

      <ul class="join-perks">
        <li>Charlas y demos</li>
        <li>Workshops prácticos</li>
      </ul>

      <a
        href="https://sessionize.com/ai-developer-day-build-with-ai-2026"
        target="_blank"
        rel="noopener"
        class="join-cta"
      >
        <span>Postula tu charla</span>
      </a>
    </div>
  </div>

  <div class="join-half sponsor">
    <div class="join-content">
      <div class="join-icon">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
          ></path>
        </svg>
      </div>

      <span class="join-eyebrow">Sponsors</span>

      <h2 class="join-title">
        ¿Tu marca apoya<br />
        la <em>comunidad IA?</em>
      </h2>

      <p class="join-desc">
        Hazte patrocinador del AI Developer Day y coloca tu marca a la cabeza de
        la industria tecnológica. Esta oportunidad excepcional te brinda la
        posibilidad de involucrarte con nuestra comunidad, recibir una
        exposición destacada y contribuir al progreso tecnológico. Tu apoyo
        impulsa la innovación y te conecta con una audiencia diversa.
      </p>

      <ul class="join-perks">
        <li>Visibilidad en el evento y redes</li>
        <li>Stand o espacio de networking</li>
        <li>Mención en comunicaciones</li>
      </ul>

      <a
        href="https://forms.gle/BFKHG3EUZ2VbNeQE9"
        target="_blank"
        rel="noopener"
        class="join-cta"
      >
        <span>Quiero ser sponsor</span>
      </a>
    </div>
  </div>
</section>

<style lang="scss">
  #join {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;

    @media (max-width: 900px) {
      grid-template-columns: 1fr;
    }
  }

  .join-half {
    padding: 100px 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;

    @media (max-width: 900px) {
      padding: 80px 28px;
    }

    &::before {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      border-radius: 4px;
      opacity: 0.09;
      transform: rotate(20deg);
    }

    &.speaker {
      background: var(--white);

      &::before {
        background: var(--blue-deep);
        top: -40px;
        right: -40px;
      }

      border-right: 1px solid rgba(66, 133, 244, 0.15);

      .join-eyebrow {
        color: var(--blue-deep);
        font-weight: 800;
      }
      .join-title em {
        color: var(--blue-mid);
      }
      .join-icon {
        background: rgba(66, 133, 244, 0.1);
        color: var(--blue-mid);
      }
      .join-perks li::before {
        background: var(--blue-mid);
      }
      .join-cta {
        font-family: var(--secondary);
        background: linear-gradient(
          89.58deg,
          #3186ff 0.28%,
          #346bf0 44.45%,
          #4ea0ff 99.55%
        );
        color: var(--white);

        &::after {
          background: linear-gradient(
            89.58deg,
            #4ea0ff 0.28%,
            #346bf0 55%,
            #3186ff 99.55%
          );
        }
      }
    }

    &.sponsor {
      background: var(--dark);

      &::before {
        background: var(--white);
        bottom: -40px;
        left: -40px;
      }

      .join-eyebrow {
        color: rgba(255, 255, 255, 0.4);
        font-weight: 800;
      }

      .join-title {
        color: var(--white);
        em {
          color: var(--blue-light);
        }
      }

      .join-desc {
        color: rgba(255, 255, 255, 0.5);
      }

      .join-icon {
        background: rgba(255, 255, 255, 0.08);
        color: var(--blue-light);
      }

      .join-perks {
        li {
          color: rgba(255, 255, 255, 0.5);
          &::before {
            background: var(--blue-light);
          }
        }
      }
      .join-cta {
        font-family: var(--secondary);
        background: transparent;
        color: var(--white);
        border: 2px solid rgba(255, 255, 255, 0.2);

        &::after {
          background: rgba(255, 255, 255, 0.06);
        }

        &:hover {
          border-color: var(--blue-light);
          box-shadow: 0 10px 28px rgba(66, 133, 244, 0.2);
        }
      }
    }
  }

  .join-content {
    max-width: 420px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .join-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;

    svg {
      width: 28px;
      height: 28px;
    }
  }

  .join-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;

    &::before {
      content: "";
      width: 16px;
      height: 1.5px;
      background: currentColor;
      opacity: 0.5;
    }
  }

  .join-title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #0d1117;
    margin-bottom: 20px;

    em {
      font-style: normal;
    }
  }

  .join-desc {
    font-size: 15px;
    line-height: 1.75;
    color: rgba(13, 17, 23, 0.55);
    margin-bottom: 28px;
  }

  .join-perks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 40px;

    li {
      font-family: var(--sans);
      font-size: 14px;
      color: rgba(13, 17, 23, 0.6);
      display: flex;
      align-items: center;
      gap: 10px;

      &::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 2px;
        flex-shrink: 0;
      }
    }
  }

  .join-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 14px;
    padding: 14px 32px;
    border-radius: 40px;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.2s,
      box-shadow 0.3s;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 40px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    span {
      position: relative;
      z-index: 1;
    }

    &:hover {
      transform: translateY(-2px);
      &::after {
        opacity: 1;
      }
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Speaker — entra desde la izquierda
  gsap.fromTo(
    ".speaker .join-content",
    { opacity: 0, x: -40 },
    {
      opacity: 1,
      x: 0,
      duration: 0.8,
      ease: "power2.out",
      scrollTrigger: { trigger: "#join", start: "top 75%" },
    },
  );

  gsap.fromTo(
    ".sponsor .join-content",
    { opacity: 0, x: 40 },
    {
      opacity: 1,
      x: 0,
      duration: 0.8,
      ease: "power2.out",
      delay: 0.15,
      scrollTrigger: { trigger: "#join", start: "top 75%" },
    },
  );
</script>
